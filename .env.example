# AVANT API Keys — copy this to .env and fill in your keys
# None of these are required — AVANT degrades gracefully without them

# ── AI Engines ────────────────────────────────────────────────
GROQ_API_KEY=           # groq.com — free, fastest
OPENROUTER_API_KEY=     # openrouter.ai — Gemini/DeepSeek/Qwen/Llama
GEMINI_API_KEY=         # aistudio.google.com — free
OPENAI_API_KEY=         # platform.openai.com — GPT-4o
DEEPSEEK_API_KEY=       # platform.deepseek.com
MISTRAL_API_KEY=        # mistral.ai
TOGETHER_API_KEY=       # together.ai
CEREBRAS_API_KEY=       # cerebras.ai

# ── Utility AI ────────────────────────────────────────────────
HUGGINGFACE_API_KEY=    # huggingface.co — embeddings, classification
JINA_API_KEY=           # jina.ai — web reader, search (1M free/month)

# ── Search & Navigation ───────────────────────────────────────
SERPAPI_KEY=            # serpapi.com — Google search (100/month free)
GOOGLE_MAPS_KEY=        # console.cloud.google.com — directions + traffic

# ── News & Media ──────────────────────────────────────────────
CURRENTS_API_KEY=       # currentsapi.services
NEWSAPI_KEY=            # newsapi.org
