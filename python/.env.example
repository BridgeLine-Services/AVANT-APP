# ╔══════════════════════════════════════════════════════════════╗
# ║         AVANT — COMPLETE FREE API KEY TEMPLATE              ║
# ║  Copy this to .env and fill in your keys                    ║
# ║  Every API below is FREE — no credit card needed            ║
# ╚══════════════════════════════════════════════════════════════╝

# ── YOUR INFO ──────────────────────────────────────────────────
OWNER_NAME=Michael
DEFAULT_HOME_ADDRESS=Your Home Address Here
DEFAULT_TIMEZONE=America/Los_Angeles
PHONE_BT_ADDRESS=XX:XX:XX:XX:XX:XX

# ════════════════════════════════════════════════════════════════
# ⚡ AI BRAINS — 7 FREE ENGINES (cascade on failure)
# ════════════════════════════════════════════════════════════════

# 1. GROQ — Llama 3.3 70B — 2000+ tokens/sec — FASTEST FREE AI
#    Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# 2. CEREBRAS — Llama 3.3 70B — 1M tokens/day FREE
#    Sign up: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_key_here

# 3. DEEPSEEK V3 — 5M FREE tokens on signup
#    Sign up: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_key_here

# 4. GEMINI 2.5 Flash — 1,500 req/day FREE — Google's best free model
#    Sign up: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# 5. MISTRAL Large — 1B free tokens/month
#    Sign up: https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_key_here

# 6. TOGETHER AI — $5 free credits — 100+ open models
#    Sign up: https://api.together.ai
TOGETHER_API_KEY=your_together_key_here

# 7. OPENAI GPT-4o — (you already have this)
#    Sign up: https://platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# ════════════════════════════════════════════════════════════════
# 🔍 SEARCH & MAPS
# ════════════════════════════════════════════════════════════════

# 8. SERPAPI — Google Search/Maps/News/Flights/Shopping (100/month free)
#    Sign up: https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here

# 9. SERPER.DEV — Google Search — 2,500 FREE searches (lifetime)
#    Sign up: https://serper.dev
SERPER_API_KEY=your_serper_key_here

# 10. GOOGLE MAPS DEMO KEY — Maps/Directions/Places (no billing required)
#     Get key: https://mapsplatform.google.com/maps-demo-key/
GOOGLE_MAPS_KEY=your_google_maps_key_here

# ════════════════════════════════════════════════════════════════
# 🌤️ WEATHER (Open-Meteo needs NO key — already works!)
# ════════════════════════════════════════════════════════════════

# 11. OPENWEATHER — Extra data: UV, air quality, alerts (1,000/day free)
#     Sign up: https://openweathermap.org/api
OPENWEATHER_KEY=your_openweather_key_here

# ════════════════════════════════════════════════════════════════
# 📰 NEWS — 3 FREE sources (600+100+100 requests/day)
# ════════════════════════════════════════════════════════════════

# 12. CURRENTS API — 600 req/day FREE — 120,000+ world sources
#     Sign up: https://currentsapi.services/en/register
CURRENTS_API_KEY=your_currents_key_here

# 13. GNEWS — 100 req/day FREE — Google News aggregator
#     Sign up: https://gnews.io/register
GNEWS_API_KEY=your_gnews_key_here

# 14. NEWSAPI — 100 req/day FREE — 80,000 sources
#     Sign up: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# ════════════════════════════════════════════════════════════════
# 🚀 NASA (free — DEMO_KEY works, register for more)
# ════════════════════════════════════════════════════════════════

# 15. NASA — APOD, Mars Rover, EPIC Earth, Near Earth Objects
#     Sign up: https://api.nasa.gov (free, instant)
NASA_API_KEY=DEMO_KEY

# ════════════════════════════════════════════════════════════════
